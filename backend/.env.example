# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ───────────────────────────────────────────
MONGO_URI=mongodb://root:rootpassword@localhost:27017/grocery?authSource=admin

# ─── Redis ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ───────────────────────────────────────────────
JWT_ACCESS_SECRET=Raju123$GroceryApp@Access2024
JWT_REFRESH_SECRET=Raju123$GroceryApp@Refresh2024
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cache TTLs (seconds) ──────────────────────────────
CACHE_TTL_PRODUCT=600
CACHE_TTL_CATEGORY=3600
CACHE_TTL_SEARCH=300
CACHE_TTL_CART=604800
